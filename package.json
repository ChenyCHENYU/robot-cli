{
  "name": "@agile-team/robot-cli",
  "version": "3.2.0",
  "description": "现代化项目脚手架工具，支持多技术栈快速创建项目 - 优先 bun，兼容 npm/pnpm/yarn",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "robot": "bin/robot.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:robot-h5": "bun scripts/smoke-robot-h5.ts",
    "lint": "oxlint src/ tests/ scripts/",
    "lint:fix": "oxlint --fix src/ tests/ scripts/",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun run test",
    "prepack": "bun run build",
    "prepublishOnly": "bun run check",
    "release:dry-run": "bun pm pack --dry-run",
    "release:publish": "bun publish --access public",
    "release:patch": "bun pm version patch",
    "release:minor": "bun pm version minor",
    "release:major": "bun pm version major"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.1.0",
    "ora": "^9.4.1",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "oxlint": "^0.16.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "cli",
    "scaffold",
    "template",
    "vue",
    "react",
    "node",
    "h5",
    "vant",
    "webview",
    "electron",
    "project-generator",
    "boilerplate",
    "bun-first",
    "package-manager-smart",
    "cheny"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "homepage": "https://github.com/ChenyCHENYU/robot-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChenyCHENYU/robot-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ChenyCHENYU/robot-cli/issues"
  },
  "author": "CHENY <ycyplus@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
